{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": ".claude/plans",
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Bash(./gradlew*)",
      "Bash(adb *)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./app/release/**)"
    ]
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Committing changes...'"
          }
        ]
      }
    ]
  }
}
